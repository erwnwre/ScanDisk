---
import type { CollectionEntry } from "astro:content";
import { render } from "astro:content";
import Window from "./Window.astro";
import { SECTIONS } from "../consts";
import StarRating from "./StarRating.astro";

interface Props {
  post: CollectionEntry<"posts">;
}
const { post } = Astro.props;
const { Content } = await render(post);
const meta = SECTIONS[post.data.section];
---
<div style="margin-bottom:1rem">
  <a href={`/${post.data.section}/`} class="button" style="box-shadow:6px 6px 0 var(--violet)">← Retour</a>
</div>

<Window title={`article / ${post.data.section}`}>
  <div class="panel-stack article-shell">
    <div>
      <span class="kicker">{meta.label} / article</span>
      <h1 class="page-title cheap-3d">{post.data.title}</h1>

      <div class="meta-row article-meta-row">
        <span class="meta-pill">{new Date(post.data.date).toLocaleDateString("fr-FR")}</span>
        <span class="meta-pill pink">{meta.label}</span>
      </div>

      {post.data.rating && (
        <div style="margin-bottom:1rem">
          <StarRating value={post.data.rating} />
        </div>
      )}

      <p class="panel-text">{post.data.excerpt}</p>
    </div>

    <div class="article-body-flow">
      <aside class="article-sidebar">
        {post.data.cover && (
          <div class="sidebar-frame">
            <img src={post.data.cover} alt={post.data.title} class="sidebar-cover-image" />
          </div>
        )}

        {post.data.youtubeEmbed && (
          <div class="video-embed sidebar-frame">
            <iframe
              title={`vid-${post.slug}`}
              src={post.data.youtubeEmbed}
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
              referrerpolicy="strict-origin-when-cross-origin"
              allowfullscreen
            ></iframe>
          </div>
        )}
      </aside>

      <div class="article-copy">
        <Content />
      </div>
    </div>
  </div>
</Window>

<style>
  .article-shell {
    gap: 1.25rem;
  }

  .article-meta-row {
    margin: 1rem 0 1.2rem;
  }

  .article-body-flow {
    display: block;
  }

  .article-sidebar {
    float: right;
    width: min(340px, 100%);
    margin: 0 0 1.25rem 1.25rem;
  }

  .sidebar-frame {
    border: 4px solid var(--violet);
    background: var(--cream);
    box-shadow: 8px 8px 0 var(--violet);
    overflow: hidden;
    margin-bottom: 1rem;
  }

  .sidebar-cover-image {
    display: block;
    width: 100%;
    height: auto;
  }

  .video-embed {
    background: var(--violet);
  }

  .video-embed iframe {
    display: block;
    width: 100%;
    aspect-ratio: 16 / 9;
    border: 0;
  }

  .article-copy {
    min-width: 0;
  }

  .article-copy::after {
    content: "";
    display: block;
    clear: both;
  }

  @media (max-width: 900px) {
    .article-sidebar {
      float: none;
      width: 100%;
      margin: 0 0 1rem 0;
    }
  }
</style>
